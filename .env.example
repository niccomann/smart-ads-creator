# AdGenius AI - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================================
# AI API KEYS
# ============================================================
OPENAI_API_KEY=sk-proj-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key-here
RUNWAYML_API_SECRET=key_your-runway-api-key-here

# ============================================================
# GITHUB API (for repository analysis)
# ============================================================
GITHUB_API_KEY=ghp_your-github-token-here

# ============================================================
# CLAUDE CODE (for AI analysis with Max subscription)
# ============================================================
CLAUDE_OAUTH_ACCESS_TOKEN=sk-ant-oat01-your-token-here

# ============================================================
# SERVER CONFIGURATION
# ============================================================
HOST=0.0.0.0
PORT=8466
ENV=dev
LOG_LEVEL=INFO
